# AI Services Gateway Configuration
PORT=3000
NODE_ENV=development

# API Authentication
# Comma-separated list of valid API keys for service-to-service authentication
API_KEYS=dev-key-1,dev-key-2,dev-key-3

# Service URLs (internal Docker network)
LLM_SERVICE_URL=http://llm-service:3001
RAG_SERVICE_URL=http://rag-service:3002
SENTIMENT_SERVICE_URL=http://sentiment-service:3003

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ChromaDB Configuration
CHROMADB_URL=http://chromadb:8000
CHROMADB_COLLECTION=default

# LLM Service Configuration
MODEL_NAME=PhoGPT-4B-Chat
MODEL_DEVICE=cuda
MODEL_PATH=/models
LLM_MAX_CONCURRENCY=5
LLM_MAX_QUEUE_SIZE=20
LLM_TIMEOUT=60000

# RAG Service Configuration
RAG_TIMEOUT=5000
RAG_TOP_K=5
RAG_MAX_RESULTS=20

# Sentiment Service Configuration
SENTIMENT_TIMEOUT=3000
SENTIMENT_MODEL=phobert-base

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Service Metadata
SERVICE_VERSION=1.0.0
SERVICE_NAME=ai-services

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100
